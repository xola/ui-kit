{
    "name": "@xola/ui-kit",
    "version": "3.0.8",
    "description": "Xola UI Kit",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git://github.com/xola/ui-kit.git"
    },
    "files": [
        "build",
        "index.css",
        "index.d.ts",
        "tailwind.config.js",
        "postcss.config.js",
        "ui-kit.es.js"
    ],
    "main": "build/ui-kit.es.js",
    "module": "build/ui-kit.es.js",
    "types": "build/index.d.ts",
    "scripts": {
        "prepare": "node scripts/prepare && vite build",
        "start": "./scripts/storybook",
        "dev": "./scripts/storybook",
        "build": "npm run prepare && vite build && cp index.d.ts build",
        "build:storybook": "npm run build && ./scripts/storybook build",
        "clean": "rm -rf node_modules/.vite",
        "lint": "xola-lint src",
        "lint:fix": "xola-lint src --fix",
        "lint:report": "xola-lint src --reporter=json src > eslint_report.json",
        "format": "prettier -l --write src",
        "test": "vitest run",
        "chromatic": "chromatic --exit-zero-on-changes --build-script-name build:storybook"
    },
    "dependencies": {
        "@headlessui/react": "1.7",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/line-clamp": "^0.4.4",
        "@tippyjs/react": "^4.2.6",
        "clsx": "^1.2.1",
        "dayjs": "^1.11.21",
        "downshift": "^6.1.12",
        "get-user-locale": "^1.5.1",
        "google-libphonenumber": "^3.2.44",
        "lodash-es": "^4.18.1",
        "nouislider-react": "^3.4.2",
        "prop-types": "^15.8.1",
        "react": "^18.3.1",
        "react-day-picker": "^7.4.10",
        "react-dom": "^18.3.1",
        "react-hot-toast": "^2.6.0",
        "react-hotkeys-hook": "^3.4.7",
        "react-select": "^5.10.2",
        "react-textarea-autosize": "^8.5.9",
        "react18-json-view": "^0.2.10",
        "tailwind-merge": "^2.6.1",
        "tippy.js": "^6.3.7"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@storybook/addon-actions": "8.6.18",
        "@storybook/addon-essentials": "8.6.18",
        "@storybook/addon-links": "8.6.18",
        "@storybook/addon-mdx-gfm": "^8.6.18",
        "@storybook/addon-postcss": "^2.0.0",
        "@storybook/addon-webpack5-compiler-babel": "^4.0.1",
        "@storybook/manager-api": "^8.6.18",
        "@storybook/react": "8.6.18",
        "@storybook/react-webpack5": "^8.6.18",
        "@storybook/test": "^8.6.18",
        "@storybook/theming": "8.6.18",
        "@types/react": "^18.3.31",
        "@types/react-dom": "^18.3.7",
        "@xola/jslint": "^3.0.1",
        "autoprefixer": "^10.5.2",
        "babel-loader": "^8.4.1",
        "chromatic": "^6.24.1",
        "postcss": "8.5",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "storybook": "^8.6.18",
        "storybook-css-modules-preset": "^1.1.1",
        "tailwindcss": "3.4",
        "typescript": "4.9",
        "vite": "^5.4.21",
        "vitest": "^2.1.9",
        "webpack": "^5.108.4"
    },
    "peerDependencies": {
        "@types/react": "^18.2.22",
        "@types/react-dom": "^18.2.7",
        "autoprefixer": "^10.3.1",
        "postcss": "^8.3.6",
        "tailwindcss": "^3.1.8",
        "vite": "^5.4.11"
    },
    "engines": {
        "node": ">=18"
    },
    "prettier": {
        "semi": true,
        "printWidth": 120,
        "trailingComma": "all",
        "singleQuote": false,
        "bracketSpacing": true,
        "useTabs": false,
        "arrowParens": "always",
        "bracketSameLine": false,
        "tabWidth": 4
    }
}
