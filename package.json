{
    "name": "@xola/ui-kit",
    "version": "3.6.0",
    "description": "Xola UI Kit",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git://github.com/xola/ui-kit.git"
    },
    "files": [
        "build",
        "index.css",
        "index.d.ts",
        "tailwind.config.js",
        "postcss.config.js",
        "ui-kit.es.js"
    ],
    "main": "build/ui-kit.es.js",
    "module": "build/ui-kit.es.js",
    "types": "build/index.d.ts",
    "scripts": {
        "prepare": "node scripts/prepare && vite build",
        "start": "./scripts/storybook",
        "dev": "./scripts/storybook",
        "build": "npm run prepare && vite build && cp index.d.ts build",
        "build:storybook": "npm run build && ./scripts/storybook build",
        "clean": "rm -rf node_modules/.vite",
        "lint": "eslint --cache --cache-strategy content --fix src",
        "lint:ci": "eslint --cache --cache-strategy content src",
        "lint:report": "eslint --cache --cache-strategy content --output-file=eslint_report.json --format=json src",
        "format": "prettier -l --write src",
        "test": "vitest run --project unit",
        "test:storybook": "vitest run --project storybook",
        "test:all": "vitest run"
    },
    "dependencies": {
        "@headlessui/react": "1.7",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/line-clamp": "^0.4.4",
        "@tippyjs/react": "^4.2.6",
        "ahooks": "^3.9.6",
        "axios": "^1.13.2",
        "clsx": "^1.2.1",
        "dayjs": "^1.11.21",
        "downshift": "^6.1.12",
        "get-user-locale": "^1.5.1",
        "google-libphonenumber": "^3.2.44",
        "lodash-es": "^4.18.1",
        "nouislider-react": "^3.4.2",
        "prop-types": "^15.8.1",
        "react-day-picker": "^7.4.10",
        "react-hot-toast": "^2.6.0",
        "react-hotkeys-hook": "^3.4.7",
        "react-select": "^5.10.2",
        "react-textarea-autosize": "^8.5.9",
        "react18-json-view": "^0.2.10",
        "tailwind-merge": "^2.6.1",
        "tippy.js": "^6.3.7",
        "use-debounce": "^10.0.6"
    },
    "devDependencies": {
        "@storybook/addon-docs": "^10.5.2",
        "@storybook/addon-links": "^10.5.2",
        "@storybook/addon-vitest": "^10.5.2",
        "@storybook/react-vite": "^10.5.2",
        "@types/react": "^18.3.31",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/browser": "^3.2.7",
        "@vitest/coverage-v8": "3.2.7",
        "@xola/jslint": "^4.0.1",
        "autoprefixer": "^10.5.2",
        "eslint": "^9.18.0",
        "playwright": "^1.61.1",
        "postcss": "8.5",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^10.5.2",
        "tailwindcss": "3.4",
        "typescript": "^5.7.2",
        "vite": "^5.4.21",
        "vitest": "^3.2.7"
    },
    "peerDependencies": {
        "@types/react": "^18.2.22",
        "@types/react-dom": "^18.2.7",
        "autoprefixer": "^10.3.1",
        "postcss": "^8.3.6",
        "react": ">=18",
        "react-dom": ">=18",
        "tailwindcss": "^3.1.8",
        "vite": "^5.4.11"
    },
    "engines": {
        "node": ">=20"
    },
    "prettier": {
        "semi": true,
        "printWidth": 120,
        "trailingComma": "all",
        "singleQuote": false,
        "bracketSpacing": true,
        "useTabs": false,
        "arrowParens": "always",
        "bracketSameLine": false,
        "tabWidth": 4
    }
}
